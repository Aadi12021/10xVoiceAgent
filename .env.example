# Vapi
VAPI_API_KEY=your_vapi_private_api_key_here
VAPI_PUBLIC_KEY=your_vapi_public_key_here      # Used for web widget embed only
VAPI_ASSISTANT_ID=                              # Filled in after running vapi/create_agent.py

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Twilio (for SMS booking links)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Notion CRM
NOTION_TOKEN=secret_your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_key

# Calendly
CALENDLY_BOOKING_URL=https://calendly.com/10xaistudio/strategy-call

# Webhook security (generate with: python3 -c "import secrets; print(secrets.token_hex(16))")
WEBHOOK_SECRET=your_32_char_random_secret_here

# App
PORT=8000
